@{
    ViewData["Title"] = "Start";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.HideServiceNavigation = true;
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link-nolink"></a>

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">

            <h1 class="govuk-heading-xl">Manage eligibility for free school meals</h1>

            <p>Local authorities can use this service to manage and check eligibility for free school meals.</p>

            <p>Sign in to:</p>

            <ul>
                <li>run single and batch eligibility checks</li>
                <li>download an eligibility form for parents</li>
                <li>generate and view reports</li>
                <li>view guidance</li>
            </ul>

            <a href="/account/sign-in" role="button" draggable="false" class="govuk-button govuk-button--start" data-module="govuk-button">
                Sign in
                <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
                    <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z" />
                </svg>
            </a>

            <h2 class="govuk-heading-m">Before you start</h2>

            <p>You'll need a <a href="https://services.signin.education.gov.uk/">DfE Sign-in account</a> to use this service.  </p>
        </div>

        <div class="govuk-grid-column-one-quarter startPageRightLinkPanel">

            <h2 class="govuk-heading-m govuk-!-margin-top-4">Help and support</h2>

            <p>Use the <a href="https://customerhelpportal.education.gov.uk/">Customer Help Portal</a> to contact us and get help. Visit the <a href="https://khub.net/c/message_boards/find_message?p_l_id=720388083&messageId=1305382187&redirect=https://khub.net/group/dfe-ecs-community/group-home?p_p_id=com_placecube_digitalplace_communities_activitystream_web_ActivityStreamPortlet&p_p_lifecycle=0&p_p_state=normal&p_p_mode=view">Knowledge Hub</a> to connect with colleagues at organisations using this service. </p>

            <h2 class="govuk-heading-m">Related content </h2>

            <p><a href="/childcare/dev/start">Manage eligibility for childcare support</a></p>

            <p><a href="/Start/UserGuidance"> User guidance: Manage eligibility for free school meals</a></p>
        </div>
    </div>
</div>
