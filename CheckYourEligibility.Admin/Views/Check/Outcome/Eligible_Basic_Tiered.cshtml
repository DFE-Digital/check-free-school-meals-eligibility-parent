@using CheckYourEligibility.Admin.Domain.DfeSignIn
@model TieredOutcomeBasic

@{
    ViewData["Title"] = "Children eligible";
    var orgType = TempData["organisationType"] as OrganisationCategory?;
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link-nolink"></a>

    <div id="content" data-type="Eligible_LA" class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <div class="govuk-notification-banner govuk-notification-banner--success" role="alert"
                 aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
                <div class="govuk-notification-banner__header">
                    <h2 class="govuk-notification-banner__title"
                        id="govuk-notification-banner-title">
                        Children eligible for @Model.Tier free school meals
                    </h2>
                </div>
                <div class="govuk-notification-banner__content">
                    <h3 class="govuk-notification-banner__heading">
                        The children of @Model.ParentGuardian.FirstName @Model.ParentGuardian.LastName are eligible for free school meals and additional support.
                    </h3>
                </div>
            </div>

            <h2 class="govuk-heading-m">Eligibility details</h2>
            <dl class="govuk-summary-list">
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">Status</dt>
                    <dd class="govuk-summary-list__value">
                        <strong class="govuk-tag govuk-tag--purple">
                            Eligible @Model.Tier
                        </strong>
                    </dd>
                </div>

                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">Eligibility end date</dt>
                    <dd class="govuk-summary-list__value"><span class="dev-todo">@Model.EligibilityEndDate"</span></dd>
                </div>
            </dl>

            @if (orgType == OrganisationCategory.LocalAuthority)
            {
                <p class="govuk-body">This information should be passed on to their school.</p>
            }
            else if (orgType == OrganisationCategory.MultiAcademyTrust)
            {
                <p class="govuk-body">This information should be passed on to their academy.</p>
            }

            <p class="govuk-body">The result of this check is valid for the academic year <span class="dev-todo">2026 to 2027</span>. You must complete annual rechecks to confirm ongoing eligibility.</p>

            <p class="govuk-body">
                @Html.ActionLink("How and when to complete annual rechecks", "Rechecks", "Home", null, new { @class = "govuk-link" })

                <div class="govuk-inset-text">
                    <p><strong>Targeted and expanded free school meals</strong></p>

                    <p>From the start of the 2026 to 2027 academic year, there will be 2 categories of eligibility for free school meals:</p>
                    <p>
                        <strong class="govuk-tag govuk-tag--purple">Targeted:</strong>
                        this covers children in households in receipt of Universal Credit with annual household earnings of £7,400 or less.
                        These children will attract pupil premium and other disadvantage funding for their schools.
                        Other education entitlements, such as the holiday activities and food programme (HAF) and the ‘extended rights’ element of school travel assistance, will be based on targeted free school meals.
                    </p>
                    <p>
                        <strong class="govuk-tag govuk-tag--green">Expanded:</strong>
                        this covers children who are in households receiving Universal Credit with annual household earnings exceeding £7,400.
                        Children will be entitled to free school meals only.
                    </p>
                    <p>
                        For more information, read
                        <a href="https://www.gov.uk/government/publications/free-school-meals-guidance-for-schools-and-local-authorities" class="govuk-link" target="_blank" rel="noopener noreferrer">
                            Free school meals: guidance for schools and local authorities.
                        </a>
                    </p>
                </div>


            <p class="govuk-body">
                You can
                <a id="print-link" href="" class="govuk-link" onclick="printPage()">print this page</a>
                for the parent or guardian to keep.
            </p>
            <div class="govuk-button-group">
                @Html.ActionLink("Do another check", "Enter_Details_Basic", "Check", null, new { @class = "govuk-button" })
            </div>
        </div>
    </div>
</div>