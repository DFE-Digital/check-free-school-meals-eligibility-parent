@model CheckYourEligibility.Admin.Boundary.Responses.EligibilityCheckReportHistoryItem

@{
    ViewData["Title"] = "Delete report generated by " + Model.GeneratedBy;
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link backLinkJS" href="@Url.Action("Reports", "EligibilityCheckReporting")">Back</a>
    
    <h1 class="govuk-heading-l">@ViewData["Title"]</h1>
    <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">Warning</span>
            This action cannot be undone. Your organisation will no longer be able to view this report if you delete it.
        </strong>
    </div>

    <form method="post" action="@Url.Action("Delete_Report", "EligibilityCheckReporting")">
        <input type="hidden" name="reportId" value="@Model.ReportID" />

        <button type="submit" class="govuk-button govuk-button--warning">
            Delete report
        </button>
    </form>

    <a class="govuk-link" href="@Url.Action("Reports", "EligibilityCheckReporting")">Cancel</a>
</div>
