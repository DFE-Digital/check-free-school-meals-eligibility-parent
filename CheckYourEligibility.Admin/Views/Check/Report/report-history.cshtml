@using CheckYourEligibility.Admin.ViewModels
@model CheckYourEligibility.Admin.Boundary.Responses.EligibilityCheckReportHistoryResponse

@{
    ViewData["Title"] = "Report history";
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link backLinkJS" href="@Url.Action("Index", "Home")">Back</a>

    <h1 class="govuk-heading-l">@ViewData["Title"]</h1>
    <a class="govuk-button" href="@Url.Action("Create_Report", "Check")">Generate report</a>

    <table class="govuk-table govuk-table--small-text-until-tablet">
        <caption class="govuk-table__caption govuk-table__caption--s govuk-!-margin-bottom-4">
            Showing @Model.TotalNumberOfRecords reports generated in the last 7 days
        </caption>

        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Report generated</th>
                <th scope="col" class="govuk-table__header">Start date</th>
                <th scope="col" class="govuk-table__header">End date</th>
                <th scope="col" class="govuk-table__header">Generated by</th>
                <th scope="col" class="govuk-table__header">Number of results</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
            </tr>
        </thead>

        <tbody class="govuk-table__body">
            @foreach (var item in Model.Data)
            {
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@item.ReportGeneratedDate.ToString("d MMM yyyy")</td>
                    <td class="govuk-table__cell">@item.StartDate.ToString("d MMM yyyy")</td>
                    <td class="govuk-table__cell">@item.EndDate.ToString("d MMM yyyy")</td>
                    <td class="govuk-table__cell">@item.GeneratedBy</td>
                    @{
                        var showResults = item.Status == "Complete";
                    }
                    <td class="govuk-table__cell">
                        @(showResults? item.NumberOfResults.ToString() : "")
                    </td>

                    @switch (item.Status)
                    {
                        case "New":
                            <td class="govuk-table__cell">
                                <strong class="govuk-tag govuk-tag--grey">Not started</strong>
                            </td>
                            <td class="govuk-table__cell"></td>
                            break;

                        case "Generating":
                            <td class="govuk-table__cell">
                                <strong class="govuk-tag govuk-tag--blue">In progress</strong>
                            </td>
                            <td class="govuk-table__cell"></td>
                            break;

                        case "Complete":
                            <td class="govuk-table__cell">
                                <strong class="govuk-tag govuk-tag--green">Complete</strong>
                            </td>
                            <td class="govuk-table__cell">
                                @Html.ActionLink( "Download report", "#", null, new { aria_label = "Download report generated on " + item.ReportGeneratedDate.ToString("d MMM yyyy") })
                            </td>
                            <td class="govuk-table__cell">
                                @Html.ActionLink("Delete", "#", null, new { aria_label = "Delete report generated on " + item.ReportGeneratedDate.ToString("d MMM yyyy") })
                            </td>
                                break;

                        case "Failed":
                            <td class="govuk-table__cell">
                                <strong class="govuk-tag govuk-tag--red">System error - try again</strong>
                            </td>
                            <td class="govuk-table__cell">
                                @Html.ActionLink("Delete", "#", null, new { aria_label = "Delete failed report generated on " + item.ReportGeneratedDate.ToString("d MMM yyyy") })
                            </td>
                                break;

                        default:
                            <td class="govuk-table__cell">@item.Status</td>
                            <td class="govuk-table__cell"></td>
                            break;
                    }
                </tr>
            }
        </tbody>
    </table>
    
    @Html.Partial("Report/ReportPagination", Model)
</div>