@using CheckYourEligibility.Admin.ViewModels
@model CheckYourEligibility.Admin.ViewModels.ReportHistoryViewModel

@{
    ViewData["Title"] = "Report history";
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link backLinkJS" href="@Url.Action("Index", "Home")">Back</a>

    <h1 class="govuk-heading-l">@ViewData["Title"]</h1>
    <a class="govuk-button" href="@Url.Action("Create_Report", "EligibilityCheckReporting")">Generate report</a>
    <p>If the status of a report is 'in progress', refresh the page to see if generating the report has completed. </p>
    <table class="govuk-table govuk-table--small-text-until-tablet">
        <caption class="govuk-table__caption govuk-table__caption--s govuk-!-margin-bottom-4">
            Showing @Model.TotalNumberOfRecords reports generated in the last 7 days
        </caption>

        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Report generated</th>
                <th scope="col" class="govuk-table__header">Start date</th>
                <th scope="col" class="govuk-table__header">End date</th>
                <th scope="col" class="govuk-table__header">Generated by</th>
                <th scope="col" class="govuk-table__header">Number of results</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header" aria-label="Download generated reports"></th>
                <th scope="col" class="govuk-table__header" aria-label="Delete generated reports"></th>
            </tr>
        </thead>

        <tbody class="govuk-table__body">
            @if (Model.Data != null)
            {
                foreach (var row in Model.Data)
                {
                    var item = row.Item;
                    var status = row.StatusBanner;

                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">
                            @item.ReportGeneratedDate.ToString("d MMM yyyy")
                        </td>

                        <td class="govuk-table__cell">
                            @item.StartDate.ToString("d MMM yyyy")
                        </td>

                        <td class="govuk-table__cell">
                            @item.EndDate.ToString("d MMM yyyy")
                        </td>

                        <td class="govuk-table__cell">
                            @item.GeneratedBy
                        </td>

                        <td class="govuk-table__cell">
                            @(status.CanDownload ? item.NumberOfResults.ToString() : "")
                        </td>

                        <td class="govuk-table__cell">
                            <strong class="govuk-tag @status.ColorTag">
                                @status.Status
                            </strong>
                        </td>

                        <td class="govuk-table__cell">
                            @if (status.CanDownload)
                            {
                                <a class="govuk-link"
                                   aria-label="Download report generated on @item.ReportGeneratedDate.ToString("d MMM yyyy")"
                                   href="/EligibilityCheckReporting/Download_Report?reportId=@item.ReportID">
                                    Download report
                                </a>
                            }
                        </td>

                        <td class="govuk-table__cell">
                            @if (status.CanDelete)
                            {
                                <a class="govuk-link"
                                   aria-label="Delete report generated on @item.ReportGeneratedDate.ToString("dd MMMM yyyy")"
                                   href="@Url.Action("Delete_Report_Confirmation", "EligibilityCheckReporting", new { reportID = item.ReportID, reportGeneratedDate = item.ReportGeneratedDate, generatedBy = item.GeneratedBy })">
                                    Delete
                                </a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    @Html.Partial("~/Views/Check/Report/ReportPagination.cshtml", Model)
</div>