@using CheckYourEligibility.Admin.Gateways.Interfaces
@using CheckYourEligibility.Admin.Infrastructure
@inject IHttpContextAccessor _httpContext
@inject IMenuProvider MenuProvider

@model CheckYourEligibility.Admin.Domain.DfeSignIn.DfeClaims;

@{
    ViewData["Title"] = "Dashboard";
    var role = Model.Roles[0].Code;
    var menu = MenuProvider.GetMenuItemsFor(role);
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link-nolink"></a>

    @if (!ViewData.ModelState.IsValid)
    {
        ViewData["Title"] = "Error: Check Details";
        <partial name="_ValidationSummary" model="ViewData.ModelState" />
    }

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <h1 class="govuk-heading-l">
                @Model.Organisation.Name
            </h1>
            <div class="govuk-grid-row">
                <div class="govuk-grid-column-full">

                    <h2 class="govuk-heading-m">
                        Manage eligibility for free school meals
                    </h2>

                    <div class="dfe-width-container dfe-dashboard-cards-container">
                        <div class="dfe-grid-container">
                            @foreach (var item in menu)
                            {
                                <div class="dfe-card">
                                    <div class="dfe-card-container">
                                        <h2 class="govuk-heading-m">
                                            <a class="govuk-link govuk-link--no-visited-state dfe-card-link--header" href="@Url.Action(item.UrlView, item.UrlController)">@item.TileText</a>
                                        </h2>
                                        <p>@item.TileSubText</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/validationSummary.js"></script>