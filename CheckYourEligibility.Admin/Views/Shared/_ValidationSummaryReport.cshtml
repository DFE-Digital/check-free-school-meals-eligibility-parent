@page
@model Microsoft.AspNetCore.Mvc.ModelBinding.ModelStateDictionary

@{
    ViewData["Title"] = "There is a problem";

    // Collect all errors
    var errors = new List<(string Field, string Error)>();

    foreach (var entry in Model)
    {
        foreach (var err in entry.Value.Errors)
        {
            errors.Add((entry.Key, err.ErrorMessage));
        }
    }

    // Group StartDate errors
    var startErrors = errors
        .Where(e => e.Field.StartsWith("StartDate"))
        .ToList();

    // Group EndDate errors
    var endErrors = errors
        .Where(e => e.Field.StartsWith("EndDate"))
        .ToList();

    // Build final ordered list
    var finalErrors = new List<(string Field, string Error)>();

    if (startErrors.Any())
    {
        // Use the first StartDate error message
        finalErrors.Add(("StartDate", startErrors.First().Error));
    }

    if (endErrors.Any())
    {
        // Use the first EndDate error message
        finalErrors.Add(("EndDate", endErrors.First().Error));
    }

    // Add any other errors (unlikely for this page)
    finalErrors.AddRange(
        errors.Where(e => !e.Field.StartsWith("StartDate") && !e.Field.StartsWith("EndDate"))
    );
}

<div class="govuk-error-summary" data-module="govuk-error-summary">
    <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
                @foreach (var err in finalErrors)
                {
                    <li>
                        <a href="#@err.Field">@err.Error</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

