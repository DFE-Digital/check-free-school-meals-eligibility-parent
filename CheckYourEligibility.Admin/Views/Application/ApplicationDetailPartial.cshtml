@using CheckYourEligibility.Admin.Domain.DfeSignIn
@using CheckYourEligibility.Admin.Domain.Enums
@model CheckYourEligibility.Admin.ViewModels.ApplicationDetailViewModel

@{
    var orgType = TempData["organisationType"] as OrganisationCategory?;
}
<div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
        <h2 class="govuk-summary-card__title">
            Application status
        </h2>
    </div>
    <div class="govuk-summary-card__content">
        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    <strong class="govuk-tag @Model.Status.GetApplicationStatusColor(Model.Tier)">
                        @Model.Status.GetApplicationStatusDescription(Model.Tier)
                    </strong>
                </dt>
                <dd class="govuk-summary-list__value">
                    @switch (Model.Status)
                    {
                        case ApplicationStatus.SentForReview:
                            @:You can now review the application as the evidence has been received.
                            break;
                        case ApplicationStatus.Archived:
                            @:This record has been archived. You can no longer make changes to this record.
                            break;
                        default:
                            @:UNHANDLED STATUS
                            break;
                    }
                </dd>
            </div>
            @*<div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    End date
                </dt>
                <dd class="govuk-summary-list__value">

</dd>
            </div> *@
        </dl>
    </div>
</div>

<div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
        <h2 class="govuk-summary-card__title">
            Child details
        </h2>
    </div>

    <div class="govuk-summary-card__content">
        <dl class="govuk-summary-list">

            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Reference
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.Reference
                </dd>
            </div>

            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Name
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.ChildName
                </dd>
            </div>

            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Date of birth
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.ChildDob
                </dd>
            </div>

            @if (orgType == OrganisationCategory.LocalAuthority)
            {
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        School
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.School
                    </dd>
                </div>
            }
            else if (orgType == OrganisationCategory.MultiAcademyTrust)
            {
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Academy
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.School
                    </dd>
                </div>
            }

            @if (Model.Status != ApplicationStatus.SentForReview)
            {
                <div class="govuk-summary-list__row">
                    <dd class="govuk-summary-list__value">
                        @if (Model.Status == ApplicationStatus.EvidenceNeeded)
                        {
                            @Html.ActionLink("Send for review", "ApplicationDetailAppealConfirmation", "application", new
                            {
                                id = Model.Id
                            }, new { @class = "govuk-button govuk-button--primary" })
                        }
                    </dd>
                </div>
            }
        </dl>
    </div>
</div>

<div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
        <h2 class="govuk-summary-card__title">
            Parent or guardian
        </h2>
    </div>

    <div class="govuk-summary-card__content">
        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Name
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.ParentName
                </dd>
            </div>

            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Date of birth
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.ParentDob
                </dd>
            </div>

            <div class="govuk-summary-list__row">
                @if (!string.IsNullOrEmpty(Model.ParentNI))
                {
                    <dt class="govuk-summary-list__key">
                        National Insurance number
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.ParentNI
                    </dd>
                }
                else
                {
                    <dt class="govuk-summary-list__key">
                        Asylum support reference number
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.ParentNas
                    </dd>
                }
            </div>


            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Email address
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.ParentEmail
                </dd>
            </div>

        </dl>
    </div>
</div>


