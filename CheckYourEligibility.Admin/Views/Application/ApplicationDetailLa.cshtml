@using CheckYourEligibility.Admin.Domain.DfeSignIn
@using CheckYourEligibility.Admin.Domain.Enums
@model CheckYourEligibility.Admin.ViewModels.ApplicationDetailViewModel

@{
    var parentName = Model.ParentName;
    ViewData["Title"] = parentName;
    var orgType = TempData["organisationType"] as OrganisationCategory?;
}

<div class="govuk-grid-column-full">
    <a class="govuk-back-link backLinkJS" href="@Url.Action("PendingApplications", "Application")">Back</a>

    @if (@Model.Status == ApplicationStatus.Archived)
    {
        <div class="govuk-error-summary" data-module="govuk-error-summary">
            <div role="alert">
                <h2 class="govuk-error-summary__title">
                    This record has been archived
                </h2>
                <div class="govuk-error-summary__body">
                    <p>You can no longer make changes to this record.</p>
                </div>
            </div>
        </div>
    }

    <div class="moj-page-header-actions">
        <div class="moj-page-header-actions__title">
            <h1 class="govuk-heading-l">@ViewData["Title"]</h1>
        </div>

        <div class="moj-page-header-actions__actions">
            <div class="moj-button-menu">
                <div class="moj-button-menu__wrapper">
                    @if (Model.Status == ApplicationStatus.Archived)
                    {
                        @Html.ActionLink("Restore record", "ApplicationRestoreSend", "application", new { id = Model.Id },
                    new
                    { @class = "govuk-button govuk-button--secondary moj-button-menu__item" })
                    }
                    else
                    {
                        @Html.ActionLink("Archive record", "ArchiveConfirmation", "application", new { id = Model.Id }, new
                        { @class = "govuk-button govuk-button--secondary moj-button-menu__item" })
                    }
                </div>
            </div>
        </div>
    </div>

    @Html.Partial("ApplicationDetailPartial", Model)


    @if (Model.Evidence != null && Model.Evidence.Count > 0)
    {
        <div class="govuk-!-padding-bottom-5"></div>

        <div class="govuk-summary-card">
            <div class="govuk-summary-card__title-wrapper">
                <h2 class="govuk-summary-card__title">
                    Supporting evidence
                </h2>
                <ul class="govuk-summary-card__actions">
                    <li class="govuk-summary-card__action">
                        @* //Is something needed here? *@
                    </li>
                </ul>
            </div>
            <div class="govuk-summary-card__content">
                <dl class="govuk-summary-list">
                    @foreach (var file in Model.Evidence)
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">
                                @file.FileName
                            </dt>
                            <dd class="govuk-summary-list__value">
                                @* <a class="govuk-link govuk-!-margin-right-3" href="@Url.Action("DownloadEvidence",
                        "Application", new { id = Model.Id, blobReference = file.StorageAccountReference })" download>
                                    Download<span class="govuk-visually-hidden"> @file.FileName</span>
                                </a> *@
                                <a class="govuk-link"
                                   href="@Url.Action("ViewEvidence", "Application", new { id = Model.Id, blobReference = file.StorageAccountReference })"
                                   target="_blank">
                                    View<span class="govuk-visually-hidden"> @file.FileName</span>
                                </a>
                            </dd>
                        </div>
                    }
                </dl>
            </div>
        </div>
    }

    @if (Model.Status == ApplicationStatus.SentForReview)
    {
        <form asp-controller="Application" asp-action="ApplicationDecision" method="post">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="govuk-form-group" data-type="Decision-form-group">
                <fieldset class="govuk-fieldset" role="group" aria-describedby="Decision-hint">
                    <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                        Record a decision
                    </legend>

                    <div id="Decision" class="govuk-hint">
                        View the supporting evidence before making a decision.
                    </div>

                    <div class="govuk-radios" data-module="govuk-radios">
                        @if (bool.Parse(ViewBag.IsExpandedFSMEnabled.ToString()))
                        {
                            <div class="govuk-radios__item">
                                <input class="govuk-radios__input" id="Decision-ApproveExpanded" type="radio" name="Decision"
                                       value="ApproveExpanded" aria-expanded="false"
                                       aria-label="Approve for expanded free school meals">
                                <label class="govuk-label govuk-radios__label" for="Decision-ApproveExpanded">
                                    Approve for expanded free school meals
                                </label>
                            </div>
                            <div class="govuk-radios__item">
                                <input class="govuk-radios__input" id="Decision-ApproveTargeted" type="radio" name="Decision"
                                       value="ApproveTargeted" aria-expanded="false"
                                       aria-label="Approve for targeted free school meals">
                                <label class="govuk-label govuk-radios__label" for="Decision-ApproveTargeted">
                                    Approve for targeted free school meals
                                </label>
                            </div>
                        }
                        else
                        {
                            <div class="govuk-radios__item">
                                <input class="govuk-radios__input" id="Decision-Approve" type="radio" value="Approve"
                                       name="Decision" aria-expanded="false" aria-label="Approve application">
                                <label class="govuk-label govuk-radios__label" for="Decision-Approve">
                                    Approve application
                                </label>
                            </div>
                        }
                        <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="Decision-Decline" type="radio" value="Decline"
                                   name="Decision" aria-expanded="false" aria-label="Decline application">
                            <label class="govuk-label govuk-radios__label" for="Decision-Decline">
                                Decline application
                            </label>
                        </div>
                    </div>
                </fieldset>
            </div>
            <div class="govuk-button-group">
                <button class="govuk-button" data-module="govuk-button">
                    Save and continue
                </button>

                @Html.ActionLink("Return to review list", "PendingApplications", "Application", null, new
                { @class = "govuk-link" })
            </div>
        </form>
    }
</div>