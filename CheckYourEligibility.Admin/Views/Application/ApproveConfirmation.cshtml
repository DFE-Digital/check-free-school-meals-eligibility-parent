@{
    ViewData["Title"] = "Approve this application?";
}

<div class="govuk-grid-column-two-thirds">
    <a class="govuk-back-link-nolink"></a>

    <h1 class="govuk-heading-l">@ViewData["Title"]</h1>
    <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">Warning</span>
            @switch(TempData["Tier"] as string)
            {
                case "expanded":
                    @:The parent or guardian will receive support towards expanded free school meals if you approve this application.
                    break;
                case "targeted":
                    @:The parent or guardian will receive support towards targeted free school meals if you approve this application.
                    break;
                default:
                    @:The parent or guardian will have to start a new application if you make a mistake.
                    break;
            }
        </strong>
    </div>

    @Html.ActionLink("Approve now", "ApplicationApproveSend", "application", new { id = TempData["AppApproveId"], tier = TempData["Tier"] }, new { @class = "govuk-button govuk-button--primary" })
    @Html.ActionLink("Return to record", "ApplicationDetail", "application", new { id = TempData["AppApproveId"] }, new { @class = "govuk-button govuk-button--secondary" })
</div>