<configuration>
	<system.webServer>
		<security>
			<requestFiltering removeServerHeader="true"/>
		</security>
		<httpProtocol>
			<customHeaders>
				<remove name="X-Powered-By"/>
				<add name="X-Frame-Options" value="DENY" />
			</customHeaders>
		</httpProtocol>
	</system.webServer>
</configuration>